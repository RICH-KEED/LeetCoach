{
  "manifest_version": 3,
  "name": "LeetCoach - AI Code Review",
  "version": "1.0.0",
  "description": "Get instant structured AI feedback on your LeetCode submissions. Supports OpenAI, Gemini, Groq, OpenRouter, and custom endpoints.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.groq.com/*",
    "https://openrouter.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*", "https://leetcode.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://leetcode.com/problems/*", "https://leetcode.com/*"],
      "js": ["page_script.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "options_page": "settings.html",
  "action": {
    "default_popup": "",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "assets/*"],
      "matches": ["https://leetcode.com/*"]
    }
  ]
}
